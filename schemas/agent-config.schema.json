{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verity-benchmark.local/schemas/agent-config.schema.json",
  "title": "Default Benchmark Agent Config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "agent_id",
    "track",
    "run_slug",
    "adapter",
    "base_url",
    "base_url_env",
    "model",
    "model_env",
    "api_key_env",
    "chat_completions_path",
    "models_path",
    "system_prompt_files",
    "temperature",
    "max_completion_tokens",
    "headers",
    "header_envs",
    "extra_body",
    "request_timeout_seconds"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "agent_id": {
      "type": "string"
    },
    "track": {
      "enum": ["reference", "custom"]
    },
    "run_slug": {
      "type": "string"
    },
    "adapter": {
      "enum": ["openai_compatible"]
    },
    "base_url": {
      "type": ["string", "null"]
    },
    "base_url_env": {
      "type": "string"
    },
    "model": {
      "type": ["string", "null"]
    },
    "model_env": {
      "type": "string"
    },
    "api_key_env": {
      "type": "string"
    },
    "chat_completions_path": {
      "type": "string"
    },
    "models_path": {
      "type": "string"
    },
    "system_prompt_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "temperature": {
      "type": "number"
    },
    "max_completion_tokens": {
      "type": "integer"
    },
    "headers": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "header_envs": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "extra_body": {
      "type": "object"
    },
    "request_timeout_seconds": {
      "type": "integer",
      "minimum": 1
    }
  }
}
