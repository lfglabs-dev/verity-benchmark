{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://verity-benchmark.local/schemas/family.schema.json",
  "title": "Benchmark Family Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_kind",
    "schema_version",
    "family_id",
    "display_name",
    "split",
    "status",
    "description",
    "implementation_ids",
    "case_ids",
    "source_languages"
  ],
  "properties": {
    "manifest_kind": {
      "const": "family"
    },
    "schema_version": {
      "type": "integer"
    },
    "family_id": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "split": {
      "enum": ["active", "backlog", "mixed"]
    },
    "status": {
      "enum": ["active", "backlog", "mixed"]
    },
    "description": {
      "type": "string"
    },
    "implementation_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "case_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_languages": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
